# Test environment file
NODE_ENV=development
PORT=3000
HOST=localhost

# Database (PostgreSQL - use localhost for testing)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/test_db

# Redis (use localhost for testing)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# PASETO Keys (test keys - NOT for production!)
PASETO_LOCAL_KEY=k4.local.test_local_key_for_development_only_do_not_use_in_production_xxxxxxxxxx
PASETO_PUBLIC_KEY=k4.public.test_public_key_for_development_only_xxxxxxxxxx
PASETO_SECRET_KEY=k4.secret.test_secret_key_for_development_only_do_not_use_in_production_xxxxxxxxxx

# Token Expiry
ACCESS_TOKEN_EXPIRY_MINUTES=15
REFRESH_TOKEN_EXPIRY_DAYS=7

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_PRETTY=true
LOG_FORMAT=pretty

# CORS
CORS_ORIGIN=*
CORS_CREDENTIALS=true
CORS_METHODS=GET,POST,PUT,DELETE,PATCH
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# Security
BCRYPT_ROUNDS=12
