      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "process_memory_bytes{type=\"rss\"}",
          "instant": false,
          "legendFormat": "RSS",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "process_memory_bytes{type=\"heap_total\"}",
