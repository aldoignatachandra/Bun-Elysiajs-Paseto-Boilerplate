{
  "name": "bun-elysia-paseto-boilerplate",
  "version": "1.0.0",
  "description": "Production-ready monolith REST API boilerplate with PASETO authentication",
  "type": "module",
  "author": "Your Name <email@example.com>",
  "license": "MIT",
  "engines": {
    "bun": ">=1.0.0"
  },
  "keywords": [
    "bun",
    "elysia",
    "paseto",
    "rest-api",
    "boilerplate",
    "postgresql",
    "redis",
    "typescript"
  ],
  "scripts": {
    "dev": "bun run --watch src/server.ts",
    "start": "bun run src/server.ts",
    "test": "bun test",
    "test:load": "RUN_LOAD_TESTS=true bun test tests/load tests/performance",
    "test:coverage": "bun test --coverage",
    "test:unit": "bun test --test-name-pattern='unit'",
    "test:integration": "bun test --test-name-pattern='integration'",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "drizzle-kit generate:pg",
    "db:migrate": "bun run scripts/migrate.ts",
    "db:seed": "bun run scripts/seed.ts",
    "db:studio": "drizzle-kit studio",
    "generate:paseto-keys": "bun run scripts/generate-paseto-keys.ts",
    "prepare": "husky install"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.0.2",
    "@elysiajs/swagger": "^1.0.2",
    "@tsoa/runtime": "^5.0.0",
    "argon2": "^0.40.0",
    "drizzle-orm": "^0.29.3",
    "elysia": "^1.0.0",
    "ioredis": "^5.10.0",
    "paseto-ts": "^2.0.5",
    "pg": "^8.20.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "tsyringe": "^4.8.0",
    "uuid": "^13.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.4.0",
    "@commitlint/config-conventional": "^18.4.0",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.18.0",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "bun-types": "^1.0.0",
    "commitlint": "^18.4.0",
    "drizzle-kit": "^0.20.0",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.0.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
