# ===========================================
# Bun Elysia PASETO Boilerplate Environment
# ===========================================
# Copy this file to .env and update the values for your setup.

# ===========================================
# SERVER CONFIGURATION
# ===========================================

# Server
NODE_ENV=development
PORT=3000
# Use localhost for local development, 0.0.0.0 for Docker
HOST=localhost

# ===========================================
# DATABASE (PostgreSQL)
# ===========================================
# For local development: use localhost
# For Docker: use postgres (service name) or leave as-is if using DATABASE_URL

# Option 1: Use DATABASE_URL (recommended)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bun_elysia_paseto

# Option 2: Use individual variables (for Docker Compose)
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=bun_elysia_paseto
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_SSL=false

# ===========================================
# REDIS
# ===========================================
# For local development: use localhost
# For Docker: use redis (service name)

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===========================================
# PASETO - Hybrid Approach
# ===========================================
# Generate keys with: bun run generate:paseto-keys

PASETO_LOCAL_KEY=k4.local.<your-generated-local-key>
PASETO_PUBLIC_KEY=k4.public.<your-generated-public-key>
PASETO_SECRET_KEY=k4.secret.<your-generated-secret-key>

# ===========================================
# TOKEN EXPIRY
# ===========================================

ACCESS_TOKEN_EXPIRY_MINUTES=15
REFRESH_TOKEN_EXPIRY_DAYS=7

# ===========================================
# RATE LIMITING
# ===========================================

RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=100

# ===========================================
# LOGGING
# ===========================================

LOG_LEVEL=debug
LOG_PRETTY=true
LOG_FORMAT=json

# ===========================================
# CORS
# ===========================================

CORS_ORIGIN=*
CORS_CREDENTIALS=true
CORS_METHODS=GET,POST,PUT,DELETE,PATCH
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Request-ID

# ===========================================
# SECURITY
# ===========================================

BCRYPT_ROUNDS=12

# ===========================================
# OBSERVABILITY CONFIGURATION (Optional)
# ===========================================
# All observability features are disabled by default.
# Enable them individually as needed.

# OpenTelemetry - Distributed Tracing
OTEL_ENABLED=false
OTEL_SERVICE_NAME=bun-elysia-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SAMPLE_RATE=1.0
OTEL_LOG_LEVEL=info

# OpenTelemetry - Feature Flags
OTEL_TRACE_HTTP=true
OTEL_TRACE_DATABASE=false
OTEL_TRACE_REDIS=false

# ===========================================
# OBSERVABILITY STACK PORTS
# ===========================================
# Ports for Prometheus, Grafana, and Jaeger services.
# Change these if you have port conflicts.

PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
JAEGER_UI_PORT=16686
JAEGER_OTLP_GRPC_PORT=4317
JAEGER_OTLP_HTTP_PORT=4318

# ===========================================
# GRAFANA CONFIGURATION
# ===========================================
# Default credentials for development - CHANGE IN PRODUCTION!

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_LOG_LEVEL=info

# ===========================================
# PROMETHEUS CONFIGURATION
# ===========================================
# Data retention settings

PROMETHEUS_RETENTION_DAYS=15
PROMETHEUS_RETENTION_SIZE=10GB

# ===========================================
# DOCKER DEVELOPMENT TOOLS (Optional)
# ===========================================
# Settings for pgAdmin and Redis Commander when using Docker Compose

# pgAdmin - PostgreSQL web management
PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=admin@bun-elysia-paseto.local
PGADMIN_DEFAULT_PASSWORD=admin

# Redis Commander - Redis web management
REDIS_COMMANDER_PORT=8081
REDIS_COMMANDER_USER=admin
REDIS_COMMANDER_PASSWORD=admin
