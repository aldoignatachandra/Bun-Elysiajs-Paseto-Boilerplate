  describe('all products routes registration', () => {
    it('should register all expected products routes', () => {
      const mockGroupApp = {
        get: jest.fn().mockReturnThis(),
        post: jest.fn().mockReturnThis(),
        patch: jest.fn().mockReturnThis(),
