# ===========================================
# Docker Environment Configuration
# ===========================================
# Copy this file to .env and update the values for your Docker setup.
# This file is specifically for Docker Compose development environment.

# Docker Port Mappings
# Configure these if you need to avoid conflicts with services running on your host
API_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379
PGADMIN_PORT=5050
REDIS_COMMANDER_PORT=8081

# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database (PostgreSQL)
# Note: Inside Docker, use service names (postgres, redis) instead of localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=bun_elysia_paseto
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_SSL=false

# Redis
REDIS_PASSWORD=
REDIS_DB=0

# PASETO - Hybrid Approach
# Generate keys with: bun run generate:paseto-keys
PASETO_LOCAL_KEY=k4.local.<your-generated-local-key>
PASETO_PUBLIC_KEY=k4.public.<your-generated-public-key>
PASETO_SECRET_KEY=k4.secret.<your-generated-secret-key>

# Token Expiry
ACCESS_TOKEN_EXPIRY_MINUTES=15
REFRESH_TOKEN_EXPIRY_DAYS=7

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug
LOG_PRETTY=true
LOG_FORMAT=json

# CORS
CORS_ORIGIN=*
CORS_CREDENTIALS=true
CORS_METHODS=GET,POST,PUT,DELETE,PATCH
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Request-ID

# Security
BCRYPT_ROUNDS=12

# Database Management Tools
# pgAdmin credentials for PostgreSQL web management
PGADMIN_DEFAULT_EMAIL=admin@bun-elysia-paseto.local
PGADMIN_DEFAULT_PASSWORD=admin

# Redis Commander credentials for Redis web management
REDIS_COMMANDER_USER=admin
REDIS_COMMANDER_PASSWORD=admin
